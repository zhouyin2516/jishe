# Internal Application Authentication Key
INTERNAL_API_KEY=your_secure_internal_token_here

# OBS Configuration
OBS_BUCKET=your_bucket_name
OBS_ENDPOINT=obs.cn-north-4.myhuaweicloud.com

# Huawei Cloud Region (IAM Region)
IAM_REGION=cn-north-4

# Development Credentials (used ONLY when USE_ECS_AGENCY=False)
DEV_AK=your_dev_access_key
DEV_SK=your_dev_secret_key
